# Public site URL (used for sitemap, Open Graph, canonical URLs)
NEXT_PUBLIC_SITE_URL=https://sierlab.com

# Google Analytics (optional — loads only after cookie consent)
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Calendly inline embed (optional), e.g. https://calendly.com/your-org/30min
NEXT_PUBLIC_CALENDLY_URL=

# Contact form — configure at least one provider:

# Resend (https://resend.com)
RESEND_API_KEY=
CONTACT_TO_EMAIL=info@sierlab.com
CONTACT_FROM_EMAIL=Sierlab <onboarding@resend.dev>

# Web3Forms (https://web3forms.com) — free alternative
WEB3FORMS_ACCESS_KEY=

# Custom webhook (Slack, Zapier, etc.)
CONTACT_WEBHOOK_URL=
